                            </table>
                        </div>
                    </div>

                    <h3 class="text-2xl font-bold mb-4 mt-8">✏️ Try It Yourself!</h3>
                    <p class="text-lg mb-6">See the difference between good and bad prompts! Write both versions and
                        compare the AI responses.</p>

                    <!-- Bad Prompt Section -->
                    <div class="bg-red-900/20 border border-red-500/30 rounded-lg p-6 mb-6">
                        <h3 class="text-2xl font-bold text-red-300 mb-4">❌ Bad Prompt</h3>
                        <p class="mb-4 text-gray-300">Write a vague, incomplete, or poorly structured prompt:</p>
                        <textarea id="bad-prompt" rows="3" placeholder="Example: 'write something about dogs'"
                            class="w-full p-3 rounded text-white bg-slate-700 border border-red-500/30 mb-3"></textarea>
                        <div class="flex gap-2">
                            <button onclick="generateBadPrompt()"
                                class="px-6 py-2 bg-red-600 hover:bg-red-700 rounded text-white font-semibold">Generate
                                Bad Response</button>
                            <button onclick="autoFillBad()"
                                class="px-6 py-2 bg-slate-700 hover:bg-slate-600 rounded text-white font-semibold">Auto-fill</button>
                        </div>

                        <div class="mt-4">
                            <label class="block font-semibold mb-2 text-red-300">AI Response to Bad Prompt:</label>
                            <pre id="output-bad"
                                class="bg-slate-900/50 border border-red-500/20 p-4 rounded whitespace-pre-wrap text-gray-300 min-h-[100px]">(Click Generate to see response)</pre>
                        </div>

                        <!-- Community Prompt Feed for Bad Prompts -->
                        <div class="community-feed mt-6 bg-slate-800/70 border border-red-500/30 rounded-lg p-6">
                            <h4 class="text-lg font-semibold text-red-300 mb-4">💬 Student-Submitted Bad Prompts</h4>
                            <div id="bad-prompts-feed" class="space-y-4">

                        <p class="mb-4 text-gray-300">Write a clear, specific, and well-structured prompt:</p>
                        <textarea id="good-prompt" rows="3"
                            placeholder="Example: 'Write a 150-word informative paragraph about Golden Retrievers, focusing on their temperament and why they make good family pets.'"
                            class="w-full p-3 rounded text-white bg-slate-700 border border-green-500/30 mb-3"></textarea>
                        <div class="flex gap-2">
                            <button onclick="generateGoodPrompt()"
                                class="px-6 py-2 bg-green-600 hover:bg-green-700 rounded text-white font-semibold">Generate
                                Good Response</button>
                            <button onclick="autoFillGood()"
                                class="px-6 py-2 bg-slate-700 hover:bg-slate-600 rounded text-white font-semibold">Auto-fill</button>
                        </div>

                        <div class="mt-4">
                            <label class="block font-semibold mb-2 text-green-300">AI Response to Good Prompt:</label>
                            <pre id="output-good"
                                class="bg-slate-900/50 border border-green-500/20 p-4 rounded whitespace-pre-wrap text-gray-300 min-h-[100px]">(Click Generate to see response)</pre>
                        </div>

                        <!-- Community Prompt Feed for Good Prompts -->
                        <div class="community-feed mt-6 bg-slate-800/70 border border-green-500/30 rounded-lg p-6">
                            <h4 class="text-lg font-semibold text-green-300 mb-4">💬 Student-Submitted Good Prompts</h4>
                            <div id="good-prompts-feed" class="space-y-4">

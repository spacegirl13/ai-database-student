                    <p class="text-lg mb-6">Review effective prompts for each subject, then practice writing your own!
                    </p>

                    <!-- Quick Reference Table -->
                    <div class="bg-purple-900/20 border border-purple-500/30 rounded-lg p-6 mb-6">
                        <h3 class="text-2xl font-bold text-purple-300 mb-4">📊 Student Prompt Examples by Subject</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full border-collapse bg-slate-900/50 rounded-lg overflow-hidden">
                                <thead>
                                    <tr class="bg-purple-900/30">

        <!-- SECTION 0: Introduction -->
        <div id="section-0" class="mission-section">
            <div class="space-y-6">
                <div class="bg-slate-800/70 backdrop-blur border border-purple-500/50 rounded-lg p-8">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-4xl pulse">✍️</span>
                        <h2 class="text-3xl font-bold text-purple-400">Prompt Engineering</h2>
                    </div>
                    <div class="space-y-4 text-lg">
                        <div class="flex justify-center my-6">
                            <img src="{{ '/images/digital-famine/textPrompts.png' | prepend: site.baseurl }}"
                                alt="Prompt Engineering Illustration"
                                class="rounded-lg border border-purple-500/30 max-w-2xl w-full">
                        </div>

                        <div class="bg-slate-900/50 border border-purple-500/20 rounded-lg p-6 mt-6">
                            <h3 class="text-xl font-semibold text-purple-300 mb-3">How AI Responds to Prompts</h3>
                            <p class="mb-4">Generative AI like ChatGPT and Claude use two key technologies:</p>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="bg-slate-800/50 p-4 rounded-lg">
                                    <p class="text-purple-400 font-semibold mb-2">🗣️ Natural Language Processing</p>
                                    <p class="text-sm">Helps AI understand and respond to human language naturally, like
                                        talking to another person.</p>
                                </div>
                                <div class="bg-slate-800/50 p-4 rounded-lg">
                                    <p class="text-purple-400 font-semibold mb-2">🧠 Machine Learning</p>
                                    <p class="text-sm">Enables AI to learn from your input and improve its responses
                                        over time.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <button onclick="goToSection(1)"
                    class="w-full bg-purple-600 hover:bg-purple-700 py-4 rounded-lg font-semibold text-lg">Begin
                    Learning</button>
            </div>
        </div>

        <!-- SECTION 1: Math -->
        <div id="section-1" class="mission-section section-hidden">
            <div class="space-y-6">
                <div class="bg-slate-800/70 backdrop-blur border border-purple-500/30 rounded-lg p-8">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-3xl font-bold">🔢 Math Practice</h2>
                        <button onclick="toggleMathTips()" class="text-3xl hover:scale-110 transition-transform" title="Show Tips">❓</button>
                    </div>

                    <!-- Collapsible Tips Section -->
                    <div id="math-tips" class="hidden mb-6 bg-blue-900/20 border border-blue-500/30 rounded-lg p-4">
                        <h4 class="text-lg font-bold text-blue-300 mb-3">💡 Good vs Bad Prompts for Math</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                            <div class="bg-green-900/30 p-3 rounded">
                                <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                <p>"Find the derivative of 3x⁴ - 2x³ step-by-step. Show all work and explain each step using the power rule."</p>
                            </div>
                            <div class="bg-red-900/30 p-3 rounded">
                                <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                <p>"What's the derivative?"</p>
                            </div>
                        </div>
                        <p class="mt-3 text-sm text-blue-200">✨ <strong>Key:</strong> Be specific, ask for step-by-step explanations, and mention the concept/rule to use.</p>
                    </div>

                    <div class="space-y-6 text-lg">
                        <p>Practice solving derivative problems with AI assistance. Click "View Prompt" to see an effective prompt, then use the Gemini API to check your work.</p>

                        <!-- Questions Container (loaded from database) -->
                        <div id="math-questions-container" class="space-y-4">
                            <p class="text-center text-purple-300">Loading questions...</p>
                        </div>
                                <div>
                                    <p class="font-semibold text-green-400 mb-2">1. Ask for Step-by-Step Solutions</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Solve this quadratic equation step-by-step: 2x² + 5x - 3
                                                = 0. Explain each step."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"Solve 2x² + 5x - 3 = 0"</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <p class="font-semibold text-green-400 mb-2">2. Request Conceptual Understanding</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Explain the concept of derivatives in calculus using a
                                                real-world example, like speed and distance."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"What are derivatives?"</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <p class="font-semibold text-green-400 mb-2">3. Get Practice Problems</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Create 5 practice problems on solving systems of linear
                                                equations with varying difficulty levels."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"Give me math problems."</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <p class="font-semibold text-green-400 mb-2">4. Check Your Work</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"I solved this problem and got x = 7. Can you verify if
                                                this is correct and identify any errors in my steps?"</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"Is this right?"</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-blue-900/20 border border-blue-500/30 rounded-lg p-4">
                            <p class="font-semibold">💡 Pro Tips for Math:</p>
                            <ul class="mt-2 space-y-1">
                                <li>• Always ask for explanations, not just answers</li>
                                <li>• Specify your grade level or course (Algebra I, Calculus, etc.)</li>
                                <li>• Request visual aids like graphs or diagrams when helpful</li>
                                <li>• Ask AI to create study guides or formula sheets</li>
                            </ul>
                        </div>

                        <!-- Interactive Activity: Prompt Builder -->
                        <div
                            class="bg-gradient-to-r from-green-900/30 to-blue-900/30 border-2 border-green-500/50 rounded-lg p-6 mt-6">
                            <h4 class="text-xl font-bold text-green-300 mb-4">🎮 Interactive: Build Your Math Prompt!
                            </h4>
                            <p class="mb-4">Fill in the blanks to create an effective math prompt:</p>

                            <div class="space-y-4 bg-slate-800/50 p-4 rounded-lg">
                                <div>
                                    <label class="block text-sm font-semibold mb-2">1. What do you want AI to
                                        do?</label>
                                    <select id="math-action"
                                        class="w-full p-2 rounded bg-slate-700 border border-green-500/30 text-white">
                                        <option value="">-- Select --</option>
                                        <option value="Solve">Solve</option>
                                        <option value="Explain">Explain</option>
                                        <option value="Create practice problems for">Create practice problems for
                                        </option>
                                        <option value="Help me understand">Help me understand</option>
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold mb-2">2. Your math topic or
                                        problem:</label>
                                    <input type="text" id="math-topic"
                                        placeholder="e.g., quadratic equations, derivatives, fractions"
                                        class="w-full p-2 rounded bg-slate-700 border border-green-500/30 text-white">
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold mb-2">3. Add details (optional):</label>
                                    <select id="math-detail"
                                        class="w-full p-2 rounded bg-slate-700 border border-green-500/30 text-white">
                                        <option value="">-- Select --</option>
                                        <option value="step-by-step">step-by-step</option>
                                        <option value="with examples">with examples</option>
                                        <option value="in simple terms">in simple terms</option>
                                        <option value="with a visual diagram">with a visual diagram</option>
                                    </select>
                                </div>

                                <button onclick="buildMathPrompt()"
                                    class="w-full bg-green-600 hover:bg-green-700 py-3 rounded-lg font-semibold mt-4">
                                    ✨ Generate My Prompt
                                </button>

                                <div id="math-prompt-output"
                                    class="hidden mt-4 p-4 bg-green-900/30 border border-green-500/50 rounded-lg">
                                    <p class="text-sm text-green-300 mb-2">Your Generated Prompt:</p>
                                    <p id="math-prompt-text" class="text-white font-semibold text-lg"></p>
                                    <button onclick="copyToClipboard('math-prompt-text')"
                                        class="mt-3 px-4 py-2 bg-green-700 hover:bg-green-600 rounded text-sm">
                                        📋 Copy to Clipboard
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <button onclick="goToSection(2)"
                    class="w-full bg-purple-600 hover:bg-purple-700 py-4 rounded-lg font-semibold text-lg">Continue to
                    Science</button>
            </div>
        </div>

        <!-- SECTION 2: Science -->
        <div id="section-2" class="mission-section section-hidden">
            <div class="space-y-6">
                <div class="bg-slate-800/70 backdrop-blur border border-purple-500/30 rounded-lg p-8">
                    <h2 class="text-3xl font-bold mb-6">🔬 Prompts for Science</h2>
                    <div class="space-y-6 text-lg">
                        <p>Use AI to explore scientific concepts, understand experiments, and make connections between
                            different topics in biology, chemistry, physics, and earth science.</p>

                        <div class="bg-green-900/20 border border-green-500/30 rounded-lg p-6">
                            <h4 class="text-xl font-bold text-green-300 mb-4">✅ Effective Science Prompts</h4>
                            <div class="space-y-4">
                                <div>
                                    <p class="font-semibold text-green-400 mb-2">1. Request Simple Explanations</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Explain photosynthesis to a 10th grader using simple
                                                language and an analogy."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"What is photosynthesis?"</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <p class="font-semibold text-green-400 mb-2">2. Connect Concepts to Real Life</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Give me 3 real-world examples of Newton's Third Law of
                                                Motion that I can observe in daily life."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"Explain Newton's Third Law."</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <p class="font-semibold text-green-400 mb-2">3. Ask for Experiment Ideas</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Suggest a simple chemistry experiment I can do at home
                                                to demonstrate acid-base reactions. List materials needed and safety
                                                precautions."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"Give me a chemistry experiment."</p>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <p class="font-semibold text-green-400 mb-2">4. Study for Tests</p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div class="bg-green-900/30 p-3 rounded">
                                            <p class="text-xs text-green-300 mb-1">✅ Good:</p>
                                            <p class="text-sm">"Create 10 quiz questions about cell structure and
                                                function, with answers. Focus on the differences between plant and
                                                animal cells."</p>
                                        </div>
                                        <div class="bg-red-900/30 p-3 rounded">
                                            <p class="text-xs text-red-300 mb-1">❌ Bad:</p>
                                            <p class="text-sm">"Help me study cells."</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-blue-900/20 border border-blue-500/30 rounded-lg p-4">
                            <p class="font-semibold">💡 Pro Tips for Science:</p>
                            <ul class="mt-2 space-y-1">
                                <li>• Ask for diagrams or visual descriptions of processes</li>
                                <li>• Request comparisons to understand differences (e.g., mitosis vs. meiosis)</li>
                                <li>• Ask AI to create study flashcards or concept maps</li>
                                <li>• Use AI to understand scientific articles or research papers</li>
                            </ul>
                        </div>

                        <!-- Interactive Activity: Drag and Drop -->
                        <div
                            class="bg-gradient-to-r from-green-900/30 to-blue-900/30 border-2 border-green-500/50 rounded-lg p-6 mt-6">
                            <h4 class="text-xl font-bold text-green-300 mb-4">🎮 Interactive: Match the Science Prompt!
                            </h4>
                            <p class="mb-4">Drag the prompt elements to create an effective science prompt:</p>

                            <div class="grid md:grid-cols-2 gap-6">
                                <!-- Draggable Elements -->
                                <div class="space-y-3">
                                    <p class="font-semibold text-green-300 mb-3">Drag these elements:</p>
                                    <div id="science-draggables" class="space-y-2">
                                        <div draggable="true" ondragstart="drag(event)" id="sci-action"
                                            class="p-3 bg-purple-600 rounded-lg cursor-move hover:bg-purple-500 transition-colors border-2 border-purple-400">
                                            <span class="font-semibold">Action:</span> "Explain photosynthesis"
                                        </div>
                                        <div draggable="true" ondragstart="drag(event)" id="sci-audience"
                                            class="p-3 bg-blue-600 rounded-lg cursor-move hover:bg-blue-500 transition-colors border-2 border-blue-400">
                                            <span class="font-semibold">Audience:</span> "to a 10th grader"
                                        </div>
                                        <div draggable="true" ondragstart="drag(event)" id="sci-format"
                                            class="p-3 bg-green-600 rounded-lg cursor-move hover:bg-green-500 transition-colors border-2 border-green-400">
                                            <span class="font-semibold">Format:</span> "using simple language and an
                                            analogy"
                                        </div>
                                    </div>
                                    <button onclick="resetScienceDrag()"
                                        class="w-full mt-3 px-4 py-2 bg-slate-600 hover:bg-slate-500 rounded text-sm">
                                        🔄 Reset
                                    </button>
                                </div>

                                <!-- Drop Zone -->
                                <div>
                                    <p class="font-semibold text-green-300 mb-3">Build your prompt here:</p>
                                    <div id="science-dropzone" ondrop="drop(event)" ondragover="allowDrop(event)"
                                        class="min-h-[200px] p-4 bg-slate-800/50 border-2 border-dashed border-green-500/50 rounded-lg">
                                        <p class="text-gray-400 text-sm mb-2">Drop elements here in order...</p>
                                        <div id="science-prompt-preview" class="space-y-2"></div>
                                    </div>
                                    <div id="science-feedback" class="mt-4 hidden p-3 rounded-lg"></div>

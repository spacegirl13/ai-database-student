                    <!-- Tips Section -->
                    <div class="bg-purple-900/20 border border-purple-500/30 rounded-lg p-6 mb-6">
                        <h4 class="text-xl font-bold text-purple-300 mb-3">💡 What Makes a Good Prompt?</h4>
                        <ul class="space-y-2 text-gray-300">
                            <li>✓ Be specific about what you want</li>
                            <li>✓ Include context and desired format</li>
                            <li>✓ Use clear, complete sentences</li>
                            <li>✓ Specify tone, length, or style if needed</li>
                            <li>✗ Avoid vague requests</li>
                            <li>✗ Don't use incomplete sentences</li>
                            <li>✗ Avoid ambiguous language</li>
                        </ul>
                    </div>

                    <!-- Complete Section -->
                    <div class="bg-blue-900/20 border border-blue-500/30 rounded-lg p-6 text-center">
